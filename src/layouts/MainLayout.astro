---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';

interface Props {
    title: string;
    bgImage?: string;
    description?: string;
    animatedBg?: boolean;
}

const { 
    title, 
    bgImage, 
    description = "Exploración de paisajes sonoros, cartografías especulativas y proyectos de arte sonoro por Nahun Saldaña.",
    animatedBg = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://naun.xyz');
const socialImageURL = new URL('/share-image.jpg', canonicalURL);

// Solo aplicamos la imagen de fondo si NO hay animación activa
const bodyStyle = (bgImage && !animatedBg)
    ? { backgroundImage: `linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url(${bgImage})` }
    : {};
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />

        <title>{title} | Nahun Saldaña</title>
        <meta name="title" content={`${title} | Nahun Saldaña`} />
        <meta name="description" content={description} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={`${title} | Nahun Saldaña`} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={socialImageURL} />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={`${title} | Nahun Saldaña`} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={socialImageURL} />

        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400&family=Playfair+Display:ital@0;1&display=swap" rel="stylesheet">

        {animatedBg && (
            <script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js" is:inline></script>
        )}
    </head>
    <body style={bodyStyle} class={animatedBg ? 'animated-bg' : ''}>
        
        {animatedBg && <div id="bg-canvas-holder"></div>}

        <Navigation />
        <main class="container">
            <slot />
        </main>

        {animatedBg && (
            <script src="/scripts/slime-bg.js" is:inline></script>
        )}
    </body>
</html>

<style>
    body {
        background-color: #000000;
        color: #e0e0e0;
        margin: 0;
        font-family: 'Inter', sans-serif;
        background-size: cover;
        background-attachment: fixed;
        background-position: center;
        min-height: 100vh;
    }
    body.animated-bg {
        background-color: #00000000;
        background-image: none !important;
    }
    .container {
        max-width: 800px;
        margin: 0 auto;
        padding: 4rem 2rem;
        position: relative;
        z-index: 1;
    }
    #bg-canvas-holder {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: -1;
        pointer-events: none;
        overflow: hidden;
    }
    #bg-canvas-holder canvas {
        display: block;
    }
</style>